{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Next",
  "version": "1.0.0",
  "identifier": "com.boris.next",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "frontendDist": "../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Next - Focus on the Right Thing",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "maximized": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "installerHooks": "nsis-hooks.nsi"
      }
    }
  }
}
